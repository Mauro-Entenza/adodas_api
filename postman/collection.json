                  "listen": "test",
                  "script": {
                    "exec": [
                      "const json = pm.response.json();",
                      "",
                      "const req = JSON.parse(pm.request.body.raw);",
                      "",
                      "pm.test('Status is 2xx', () => {",
                      "    pm.expect(pm.response.code).to.be.within(200, 299);",
                      "});",
                      "",
                      "pm.test('Response time < 2000ms', () => {",
                      "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                      "});",
                      "",
                      "pm.test('Body is JSON', () => {",
                      "    pm.response.to.be.json;",
                      "});",
                      "",
                      "pm.test('Has id', () => {",
                      "    pm.expect(json.id).to.exist;",
                      "});",
                      "",
                      "pm.test('Fields match request data', () => {",
                      "    pm.expect(json.name).to.eql(req.name);",
                      "    pm.expect(json.description).to.eql(req.description);",
                      "    pm.expect(json.price).to.eql(req.price);",
                      "    pm.expect(json.active).to.eql(req.active);",
                      "    pm.expect(json.availableFrom).to.eql(req.availableFrom);",
                      "    pm.expect(json.availableTo).to.eql(req.availableTo);",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{apiToken}}",
                    "type": "text"
                  },
                  {
